  <!-- ================================================================
       TRANSFORM: Extrair Artigos
       Loop XPath: .//ARTIGO-PUBLICADO
       lattes_id extraído com XPath absoluto do nó raiz
       ================================================================ -->
  <transform>
    <name>Extrair Artigos</name>
    <type>GetXmlData</type>
    <description>Loop em .//ARTIGO-PUBLICADO — um registro por artigo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <rownum_field/>
    <encoding>ISO-8859-1</encoding>
    <IsInFields>Y</IsInFields>
    <IsAFile>Y</IsAFile>
    <XmlField>filename</XmlField>
    <prunePath/>
    <loopxpath>.//ARTIGO-PUBLICADO</loopxpath>
    <fields>
      <field>
        <name>lattes_id</name>
        <xpath>/CURRICULO-VITAE/@NUMERO-IDENTIFICADOR</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>16</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>titulo</name>
        <xpath>DADOS-BASICOS-DO-ARTIGO/@TITULO-DO-ARTIGO</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>500</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>ano_publicacao</name>
        <xpath>DADOS-BASICOS-DO-ARTIGO/@ANO-DO-ARTIGO</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>Integer</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>4</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>doi</name>
        <xpath>DADOS-BASICOS-DO-ARTIGO/@DOI</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>nome_veiculo</name>
        <xpath>DETALHAMENTO-DO-ARTIGO/@TITULO-DO-PERIODICO-OU-REVISTA</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>issn</name>
        <xpath>DETALHAMENTO-DO-ARTIGO/@ISSN</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>9</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <GUI>
      <xloc>320</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>

