        <length>4</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>doi</name>
        <xpath>DADOS-BASICOS-DO-CAPITULO/@DOI</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>nome_veiculo</name>
        <xpath>DETALHAMENTO-DO-CAPITULO/@TITULO-DO-LIVRO</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>issn</name>
        <xpath>@ISSN</xpath>
        <element_type>Attribute</element_type>
        <result_type>valueof</result_type>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>9</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <GUI>
      <xloc>320</xloc>
      <yloc>600</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORMS: AddConstants — adiciona tipo_producao a cada fluxo
       ================================================================ -->
  <transform>
    <name>Tipo Artigo</name>
    <type>Constant</type>
    <description>Adiciona tipo_producao=ARTIGO</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>tipo_producao</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <nullif>ARTIGO</nullif>
        <length>20</length>
        <precision>-1</precision>
      </field>
    </fields>
    <GUI>
      <xloc>540</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tipo Evento</name>
    <type>Constant</type>
    <description>Adiciona tipo_producao=EVENTO</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>tipo_producao</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <nullif>EVENTO</nullif>
        <length>20</length>
        <precision>-1</precision>
      </field>
    </fields>
    <GUI>
      <xloc>540</xloc>
      <yloc>300</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tipo Livro</name>
    <type>Constant</type>
    <description>Adiciona tipo_producao=LIVRO</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>tipo_producao</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <nullif>LIVRO</nullif>
        <length>20</length>
        <precision>-1</precision>
      </field>
    </fields>
    <GUI>
      <xloc>540</xloc>
      <yloc>450</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Tipo Capitulo</name>
    <type>Constant</type>
    <description>Adiciona tipo_producao=CAPITULO</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>tipo_producao</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <nullif>CAPITULO</nullif>
        <length>20</length>
        <precision>-1</precision>
      </field>
    </fields>
    <GUI>
      <xloc>540</xloc>
      <yloc>600</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORM: Unificar os 4 fluxos de produção
       Append Streams: combina artigos + eventos + livros + capítulos
       ================================================================ -->

  <!-- ================================================================
       TRANSFORM: Normalizar ISSN e Título (Modified JavaScript Value)
       - ISSN: remove não-numéricos, insere hífen na posição 4
       - Título: trim, remove caracteres de controle
       ================================================================ -->
  <transform>
    <name>Normalizar ISSN e Titulo</name>
    <type>ScriptValueMod</type>
    <description>Normaliza ISSN (hífen na posição 4) e título (trim + controle)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Normalizar</jsScript_name>
        <jsScript_script>
// Normalizar titulo: trim e colapsar whitespace
if (titulo != null) {
  titulo = titulo.trim().replace(/\s+/g, ' ');
  if (titulo.length == 0) { titulo = null; }
}

// Normalizar DOI: NULL se vazio
if (doi != null) {
  doi = doi.trim();
  if (doi.length == 0) { doi = null; }
}

// Normalizar ISSN: remove nao-numericos e formata com hifen
if (issn != null) {
  var issnRaw = issn.toString().trim();
  var issnClean = issnRaw.replace(/[^0-9Xx]/g, '');
  if (issnClean.length == 8) {
    issn = issnClean.substring(0, 4) + '-' + issnClean.substring(4);
  } else if (issnClean.length == 0) {
    issn = null;
  } else {
    issn = null;
  }
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>titulo</name>
        <rename>titulo</rename>
        <type>String</type>
        <length>500</length>
        <precision>-1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>issn</name>
        <rename>issn</rename>
        <type>String</type>
        <length>9</length>
        <precision>-1</precision>
        <replace>Y</replace>
      </field>
      <field>
        <name>doi</name>
        <rename>doi</rename>
        <type>String</type>
        <length>255</length>
        <precision>-1</precision>
        <replace>Y</replace>
      </field>
    </fields>
    <GUI>
      <xloc>960</xloc>
      <yloc>375</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORM: Buscar pesquisador_id por lattes_id
       Database Lookup na tabela pesquisadores
       ================================================================ -->
  <transform>
    <name>Buscar pesquisador_id</name>
    <type>DBLookup</type>
    <description>Resolve lattes_id → pesquisador_id na tabela pesquisadores</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>spark_db</connection>
    <lookup>
      <schema>public</schema>
      <table>pesquisadores</table>
      <orderby/>
      <fail_on_multiple>N</fail_on_multiple>
      <eat_row_on_failure>N</eat_row_on_failure>
      <cache>Y</cache>
      <cache_size>5000</cache_size>
      <cache_load_all>N</cache_load_all>
      <key>
        <name>lattes_id</name>
        <field>lattes_id</field>
        <condition>=</condition>
        <name2/>
      </key>
      <value>
        <name>id</name>
        <rename>pesquisador_id</rename>
        <default/>
        <type>Integer</type>
      </value>
    </lookup>
    <GUI>
      <xloc>1160</xloc>
      <yloc>375</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORM: UPSERT na tabela producoes
       Chave: (pesquisador_id, titulo, ano_publicacao)
       COALESCE preserva doi/resumo/qualis/jcr já preenchidos
       ================================================================ -->
  <transform>
    <name>Filtrar Sem Match</name>
    <type>FilterRows</type>
    <description>Descarta producoes sem pesquisador_id</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>pesquisador_id</leftvalue>
        <function>IS NOT NULL</function>
        <rightvalue/>
      </condition>
    </compare>
    <send_true_to>UPSERT Producoes</send_true_to>
    <send_false_to/>
    <GUI>
      <xloc>1175</xloc>
      <yloc>375</yloc>
    </GUI>
  </transform>
  <transform>
    <name>UPSERT Producoes</name>
    <type>ExecSQL</type>
    <description>Insere ou atualiza produção com ON CONFLICT (pesquisador_id, titulo, ano_publicacao)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>spark_db</connection>
    <execute_each_row>Y</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <set_params>Y</set_params>
    <sql>INSERT INTO producoes
  (pesquisador_id, titulo, tipo_producao, ano_publicacao,
   nome_veiculo, issn, doi, resumo, qualis, jcr)
VALUES (?, ?, ?, ?, ?, ?, ?, NULL, NULL, NULL)
ON CONFLICT (pesquisador_id, titulo, ano_publicacao) DO UPDATE SET
  doi          = COALESCE(EXCLUDED.doi, producoes.doi),
  resumo       = COALESCE(EXCLUDED.resumo, producoes.resumo),
  qualis       = COALESCE(EXCLUDED.qualis, producoes.qualis),
  jcr          = COALESCE(EXCLUDED.jcr, producoes.jcr),
  nome_veiculo = EXCLUDED.nome_veiculo;</sql>
    <arguments>
      <argument><name>pesquisador_id</name></argument>
      <argument><name>titulo</name></argument>
      <argument><name>tipo_producao</name></argument>
      <argument><name>ano_publicacao</name></argument>
      <argument><name>nome_veiculo</name></argument>
      <argument><name>issn</name></argument>
      <argument><name>doi</name></argument>
    </arguments>
    <GUI>
      <xloc>1360</xloc>
      <yloc>375</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORM: Log de erros de parse (destino do error handling)
       ================================================================ -->
  <transform>
    <name>Log Erro Parse</name>
    <type>WriteToLog</type>
    <description>Registra arquivos com erro de parse sem interromper o batch</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <loglevel>Error</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>ERRO ao processar XML — arquivo ignorado, processamento continua</logmessage>
    <fields>
      <field>
        <name>filename</name>
      </field>
    </fields>
    <GUI>
      <xloc>540</xloc>
      <yloc>750</yloc>
    </GUI>
  </transform>

  <transform_error_handling>
    <error>
      <source_transform>Extrair Artigos</source_transform>
      <target_transform>Log Erro Parse</target_transform>
      <enabled>Y</enabled>
      <nr_valuename>ErrorCount</nr_valuename>
      <descriptions_valuename>ErrorDescription</descriptions_valuename>
      <fields_valuename>ErrorFields</fields_valuename>
      <codes_valuename>ErrorCodes</codes_valuename>
      <max_errors/>
      <max_pct_errors/>
      <min_pct_rows/>
    </error>
    <error>
      <source_transform>Extrair Eventos</source_transform>
      <target_transform>Log Erro Parse</target_transform>
      <enabled>Y</enabled>
      <nr_valuename>ErrorCount</nr_valuename>
      <descriptions_valuename>ErrorDescription</descriptions_valuename>
      <fields_valuename>ErrorFields</fields_valuename>
      <codes_valuename>ErrorCodes</codes_valuename>
      <max_errors/>
      <max_pct_errors/>
      <min_pct_rows/>
    </error>
    <error>
      <source_transform>Extrair Livros</source_transform>
      <target_transform>Log Erro Parse</target_transform>
      <enabled>Y</enabled>
      <nr_valuename>ErrorCount</nr_valuename>
      <descriptions_valuename>ErrorDescription</descriptions_valuename>
      <fields_valuename>ErrorFields</fields_valuename>
      <codes_valuename>ErrorCodes</codes_valuename>
      <max_errors/>
      <max_pct_errors/>
      <min_pct_rows/>
    </error>
    <error>
      <source_transform>Extrair Capitulos</source_transform>
      <target_transform>Log Erro Parse</target_transform>
      <enabled>Y</enabled>
      <nr_valuename>ErrorCount</nr_valuename>
      <descriptions_valuename>ErrorDescription</descriptions_valuename>
      <fields_valuename>ErrorFields</fields_valuename>
      <codes_valuename>ErrorCodes</codes_valuename>
      <max_errors/>
      <max_pct_errors/>
      <min_pct_rows/>
    </error>
  </transform_error_handling>
</pipeline>
