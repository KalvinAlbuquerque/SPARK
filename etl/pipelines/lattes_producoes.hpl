<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>lattes_producoes</name>
    <name_hi_res/>
    <description>Extrai produções científicas dos XMLs Lattes (artigos, eventos, livros, capítulos) e carrega na tabela producoes via UPSERT</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_status>0</pipeline_status>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>XML_DIR</name>
        <default_value>../../data/xml</default_value>
        <description>Diretório com os arquivos XML Lattes</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>SPARK ETL</created_user>
    <created_date>2026/05/22 00:00:00.000</created_date>
    <modified_user>SPARK ETL</modified_user>
    <modified_date>2026/05/22 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAA/wMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads>
    <notepad>
      <note>Pipeline SPK-11 / SPK-37
4 fluxos de produção (ARTIGO, EVENTO, LIVRO, CAPITULO)
unificados via Append Streams.
Requer que lattes_pesquisadores.hpl tenha rodado antes
(lookup de pesquisador_id por lattes_id).</note>
      <xloc>50</xloc>
      <yloc>50</yloc>
      <width>450</width>
      <heigth>90</heigth>
      <fontname>Arial</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>14</fontcolorred>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorblue>90</fontcolorblue>
      <backgroundcolorred>201</backgroundcolorred>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorblue>251</backgroundcolorblue>
      <bordercolorred>14</bordercolorred>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorblue>90</bordercolorblue>
    </notepad>
  </notepads>
  <order>
    <!-- Artigos -->
    <hop>
      <from>Listar XMLs Artigos</from>
      <to>Extrair Artigos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Artigos</from>
      <to>Tipo Artigo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tipo Artigo</from>
      <to>Normalizar ISSN e Titulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Artigos</from>
      <to>Log Erro Parse</to>
      <enabled>Y</enabled>
    </hop>
    <!-- Eventos -->
    <hop>
      <from>Listar XMLs Eventos</from>
      <to>Extrair Eventos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Eventos</from>
      <to>Tipo Evento</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tipo Evento</from>
      <to>Normalizar ISSN e Titulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Eventos</from>
      <to>Log Erro Parse</to>
      <enabled>Y</enabled>
    </hop>
    <!-- Livros -->
    <hop>
      <from>Listar XMLs Livros</from>
      <to>Extrair Livros</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Livros</from>
      <to>Tipo Livro</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tipo Livro</from>
      <to>Normalizar ISSN e Titulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Livros</from>
      <to>Log Erro Parse</to>
      <enabled>Y</enabled>
    </hop>
    <!-- Capítulos -->
    <hop>
      <from>Listar XMLs Capitulos</from>
      <to>Extrair Capitulos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Capitulos</from>
      <to>Tipo Capitulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tipo Capitulo</from>
      <to>Normalizar ISSN e Titulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Extrair Capitulos</from>
      <to>Log Erro Parse</to>
      <enabled>Y</enabled>
    </hop>
    <!-- Fluxo principal após unificação -->
    <hop>
      <from>Normalizar ISSN e Titulo</from>
      <to>Buscar pesquisador_id</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Buscar pesquisador_id</from>
      <to>Filtrar Sem Match</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filtrar Sem Match</from>
      <to>UPSERT Producoes</to>
      <enabled>Y</enabled>
    </hop>
  </order>

  <!-- ================================================================
       TRANSFORM: Listar XMLs — Artigos
       (um GetFileNames por fluxo para enviar mesma lista a cada parser)
       ================================================================ -->
  <transform>
    <name>Listar XMLs Artigos</name>
    <type>GetFileNames</type>
    <description>Lista XMLs para o fluxo de artigos</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filter>
      <filterfiletype>all_files</filterfiletype>
    </filter>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <rownum>N</rownum>
    <rownumField/>
    <isaddresult>N</isaddresult>
    <filefield>N</filefield>
    <filename_Field/>
    <wildcard_Field/>
    <exclude_wildcard_Field/>
    <dynamic_include_subfolders>N</dynamic_include_subfolders>
    <limit>0</limit>
    <file>
      <name>${XML_DIR}</name>
      <filemask>.*\.xml$</filemask>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <GUI>
      <xloc>100</xloc>
      <yloc>150</yloc>
    </GUI>
  </transform>

  <transform>
    <name>Listar XMLs Eventos</name>
    <type>GetFileNames</type>
    <description>Lista XMLs para o fluxo de eventos</description>
