<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>crossref_enriquecimento</name>
    <name_hi_res/>
    <description>Enriquece producoes com DOI e resumo via CrossRef API (SPK-13 subetapa 5.2)</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_status>0</pipeline_status>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>ETL_EMAIL</name>
        <default_value>spark@email.com</default_value>
        <description>Email para o Polite Pool da CrossRef API (User-Agent header)</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>SPARK ETL</created_user>
    <created_date>2026/05/23 00:00:00.000</created_date>
    <modified_user>SPARK ETL</modified_user>
    <modified_date>2026/05/23 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAA/wMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads>
    <notepad>
      <note>Pipeline SPK-13 — CrossRef (subetapa 5.2)
Ramo A (com DOI): GET /works/{doi}?select=DOI,title,abstract → extrai resumo
Ramo B (sem DOI): GET /works?query.bibliographic={titulo}&amp;rows=1 → filtra score &gt; 70 → extrai DOI + resumo
UPSERT: UPDATE producoes SET doi=COALESCE(novo,doi), resumo=COALESCE(novo,resumo) WHERE id=?
Log: sem_match_doi (score &lt;= 70), sem_resumo (sem abstract)
Requisito: ETL_EMAIL configurado em .env para Polite Pool</note>
      <xloc>50</xloc>
      <yloc>50</yloc>
      <width>620</width>
      <heigth>110</heigth>
      <fontname>Arial</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>14</fontcolorred>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorblue>90</fontcolorblue>
      <backgroundcolorred>201</backgroundcolorred>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorblue>251</backgroundcolorblue>
      <bordercolorred>14</bordercolorred>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorblue>90</bordercolorblue>
    </notepad>
  </notepads>

  <order>
    <!-- Fluxo principal -->
    <hop><from>Ler Artigos</from><to>Separar por DOI</to><enabled>Y</enabled></hop>

    <!-- Ramo A: com DOI -->
    <hop><from>Separar por DOI</from><to>Construir URL DOI</to><enabled>Y</enabled></hop>
    <hop><from>Construir URL DOI</from><to>HTTP CrossRef DOI</to><enabled>Y</enabled></hop>
    <hop><from>HTTP CrossRef DOI</from><to>Extrair Abstract DOI</to><enabled>Y</enabled></hop>
    <hop><from>Extrair Abstract DOI</from><to>Normalizar Schema DOI</to><enabled>Y</enabled></hop>
    <hop><from>Normalizar Schema DOI</from><to>Reunir Ramos</to><enabled>Y</enabled></hop>

    <!-- Ramo B: sem DOI -->
    <hop><from>Separar por DOI</from><to>Construir URL Titulo</to><enabled>Y</enabled></hop>
    <hop><from>Construir URL Titulo</from><to>HTTP CrossRef Titulo</to><enabled>Y</enabled></hop>
    <hop><from>HTTP CrossRef Titulo</from><to>Extrair Match Titulo</to><enabled>Y</enabled></hop>
    <hop><from>Extrair Match Titulo</from><to>Filtrar Score</to><enabled>Y</enabled></hop>
    <hop><from>Filtrar Score</from><to>Normalizar Schema Titulo</to><enabled>Y</enabled></hop>
    <hop><from>Normalizar Schema Titulo</from><to>Reunir Ramos</to><enabled>Y</enabled></hop>
    <hop><from>Filtrar Score</from><to>Log sem_match_doi</to><enabled>Y</enabled></hop>

    <!-- Pós-reunião -->
    <hop><from>Reunir Ramos</from><to>UPSERT DOI e Resumo</to><enabled>Y</enabled></hop>
    <hop><from>UPSERT DOI e Resumo</from><to>Filtrar sem resumo</to><enabled>Y</enabled></hop>
    <hop><from>Filtrar sem resumo</from><to>Log sem_resumo</to><enabled>Y</enabled></hop>
  </order>

  <!-- ================================================================
       ENTRADA — Lê todos os artigos
       ================================================================ -->
  <transform>
    <name>Ler Artigos</name>
    <type>TableInput</type>
    <description>Le todos os artigos da tabela producoes para enriquecimento CrossRef</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>spark_db</connection>
    <sql>SELECT id, titulo, doi FROM producoes WHERE tipo_producao = 'ARTIGO'</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <GUI><xloc>150</xloc><yloc>300</yloc></GUI>
  </transform>

  <!-- ================================================================
       ROTEAMENTO — Separa artigos com DOI dos sem DOI
       ================================================================ -->
  <transform>
    <name>Separar por DOI</name>
    <type>FilterRows</type>
    <description>Artigos COM doi vao para busca direta; SEM doi vao para busca por titulo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Construir URL DOI</send_true_to>
    <send_false_to>Construir URL Titulo</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>doi</leftvalue>
        <function>IS NOT NULL</function>
        <rightvalue/>
      </condition>
    </compare>
    <GUI><xloc>370</xloc><yloc>300</yloc></GUI>
  </transform>

  <!-- ================================================================
       RAMO A — Artigos com DOI
       ================================================================ -->
  <transform>
    <name>Construir URL DOI</name>
    <type>ScriptValueMod</type>
    <description>Monta URL CrossRef para busca por DOI e header User-Agent</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script><![CDATA[
var doi_enc = encodeURIComponent(String(doi));
var url = "https://api.crossref.org/works/" + doi_enc + "?select=DOI,title,abstract";
var user_agent = "SPARK-ETL/1.0 (mailto:" + parent.getVariable("ETL_EMAIL", "spark@email.com") + ")";
        ]]></jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>url</name>
        <rename>url</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>user_agent</name>
        <rename>user_agent</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <GUI><xloc>590</xloc><yloc>180</yloc></GUI>
  </transform>

  <transform>
    <name>HTTP CrossRef DOI</name>
    <type>HTTP</type>
    <description>Chama CrossRef GET /works/{doi} para obter abstract</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <url/>
    <urlField>url</urlField>
    <urlInField>Y</urlInField>
    <encoding>UTF-8</encoding>
    <resultfieldname>json_response</resultfieldname>
    <resultcodefield>http_status</resultcodefield>
    <resultResponseField/>
    <connectTimeout>30000</connectTimeout>
    <readTimeout>30000</readTimeout>
    <httpLogin/>
    <httpPassword/>
    <proxyHost/>
    <proxyPort/>
    <parameters/>
    <headers>
      <header>
        <field>user_agent</field>
        <name>User-Agent</name>
      </header>
    </headers>
    <GUI><xloc>810</xloc><yloc>180</yloc></GUI>
  </transform>

  <transform>
    <name>Extrair Abstract DOI</name>
    <type>ScriptValueMod</type>
    <description>Extrai resumo do JSON CrossRef (resposta por DOI). Erros de API resultam em null.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script><![CDATA[
var doi_novo = String(doi);
var resumo_novo = null;
try {
  if (String(http_status) == "200" && json_response != null && String(json_response) != "") {
    var resp = JSON.parse(String(json_response));
    if (resp.message) {
      if (resp.message.DOI) { doi_novo = String(resp.message.DOI); }
      if (resp.message.abstract) {
        var r = String(resp.message.abstract).replace(/<[^>]+>/g, "").trim();
        if (r.length > 0) { resumo_novo = r; }
      }
    }
  }
} catch(e) {}
        ]]></jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>doi_novo</name>
        <rename>doi_novo</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>resumo_novo</name>
        <rename>resumo_novo</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <GUI><xloc>1030</xloc><yloc>180</yloc></GUI>
  </transform>

  <transform>
    <name>Normalizar Schema DOI</name>
    <type>SelectValues</type>
    <description>Mantém apenas os campos necessários antes do AppendStreams</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>id</name></field>
      <field><name>doi_novo</name></field>
      <field><name>resumo_novo</name></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <removes/>
    <metas/>
    <GUI><xloc>1250</xloc><yloc>180</yloc></GUI>
  </transform>

  <!-- ================================================================
       RAMO B — Artigos sem DOI (busca por título)
       ================================================================ -->
  <transform>
    <name>Construir URL Titulo</name>
    <type>ScriptValueMod</type>
    <description>Monta URL CrossRef para busca por titulo bibliografico e header User-Agent</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script><![CDATA[
var titulo_enc = encodeURIComponent(String(titulo));
var url = "https://api.crossref.org/works?query.bibliographic=" + titulo_enc + "&rows=1&select=DOI,title,abstract,score";
var user_agent = "SPARK-ETL/1.0 (mailto:" + parent.getVariable("ETL_EMAIL", "spark@email.com") + ")";
        ]]></jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>url</name>
        <rename>url</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>user_agent</name>
        <rename>user_agent</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <GUI><xloc>590</xloc><yloc>420</yloc></GUI>
  </transform>

  <transform>
    <name>HTTP CrossRef Titulo</name>
    <type>HTTP</type>
    <description>Chama CrossRef GET /works?query.bibliographic={titulo} para buscar DOI + abstract</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <url/>
    <urlField>url</urlField>
    <urlInField>Y</urlInField>
    <encoding>UTF-8</encoding>
    <resultfieldname>json_response</resultfieldname>
    <resultcodefield>http_status</resultcodefield>
    <resultResponseField/>
    <connectTimeout>30000</connectTimeout>
    <readTimeout>30000</readTimeout>
    <httpLogin/>
    <httpPassword/>
    <proxyHost/>
    <proxyPort/>
    <parameters/>
    <headers>
      <header>
        <field>user_agent</field>
        <name>User-Agent</name>
      </header>
    </headers>
    <GUI><xloc>810</xloc><yloc>420</yloc></GUI>
  </transform>

  <transform>
    <name>Extrair Match Titulo</name>
    <type>ScriptValueMod</type>
    <description>Extrai DOI, resumo e flag de match (score &gt; 70) do JSON CrossRef</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script><![CDATA[
var doi_novo = null;
var resumo_novo = null;
var match_encontrado = "N";
try {
  if (String(http_status) == "200" && json_response != null && String(json_response) != "") {
    var resp = JSON.parse(String(json_response));
    if (resp.message && resp.message.items && resp.message.items.length > 0) {
      var item = resp.message.items[0];
      var score_val = Number(item.score) || 0;
      if (score_val > 70) {
        match_encontrado = "Y";
        if (item.DOI) { doi_novo = String(item.DOI); }
        if (item.abstract) {
          var r = String(item.abstract).replace(/<[^>]+>/g, "").trim();
          if (r.length > 0) { resumo_novo = r; }
        }
      }
    }
  }
} catch(e) {}
        ]]></jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>doi_novo</name>
        <rename>doi_novo</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>resumo_novo</name>
        <rename>resumo_novo</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>match_encontrado</name>
        <rename>match_encontrado</rename>
        <type>String</type>
        <length>1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <GUI><xloc>1030</xloc><yloc>420</yloc></GUI>
  </transform>

  <transform>
    <name>Filtrar Score</name>
    <type>FilterRows</type>
    <description>Score &gt; 70: envia para UPSERT. Score &lt;= 70: registra sem_match_doi no log</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Normalizar Schema Titulo</send_true_to>
    <send_false_to>Log sem_match_doi</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>match_encontrado</leftvalue>
        <function>=</function>
        <rightvalue/>
        <rightExact>
          <value>
            <name/>
            <type>String</type>
            <text>Y</text>
            <length>-1</length>
            <precision>-1</precision>
            <isnull>N</isnull>
            <mask/>
          </value>
        </rightExact>
      </condition>
    </compare>
    <GUI><xloc>1250</xloc><yloc>420</yloc></GUI>
  </transform>

  <transform>
    <name>Normalizar Schema Titulo</name>
    <type>SelectValues</type>
    <description>Mantém apenas os campos necessários antes do AppendStreams</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>id</name></field>
      <field><name>doi_novo</name></field>
      <field><name>resumo_novo</name></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <removes/>
    <metas/>
    <GUI><xloc>1470</xloc><yloc>420</yloc></GUI>
  </transform>

  <transform>
    <name>Log sem_match_doi</name>
    <type>WriteToLog</type>
    <description>Registra artigos sem DOI cujo titulo nao obteve score suficiente na CrossRef</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <loglevel>Error</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>SEM MATCH DOI — titulo nao encontrado na CrossRef com score &gt; 70</logmessage>
    <fields>
      <field><name>id</name></field>
      <field><name>titulo</name></field>
    </fields>
    <GUI><xloc>1470</xloc><yloc>560</yloc></GUI>
  </transform>

  <!-- ================================================================
       REUNIÃO — Junta os dois ramos
       ================================================================ -->
  <transform>
    <name>Reunir Ramos</name>
    <type>AppendStreams</type>
    <description>Reune artigos com DOI e artigos sem DOI (com match) em um unico fluxo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <headStreamName>Normalizar Schema DOI</headStreamName>
    <tailStreamName>Normalizar Schema Titulo</tailStreamName>
    <GUI><xloc>1690</xloc><yloc>300</yloc></GUI>
  </transform>

  <!-- ================================================================
       UPSERT — Grava doi e resumo preservando valores existentes
       ================================================================ -->
  <transform>
    <name>UPSERT DOI e Resumo</name>
    <type>ExecSQL</type>
    <description>Atualiza doi e resumo preservando valores ja preenchidos via COALESCE</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>spark_db</connection>
    <execute_each_row>Y</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <set_params>Y</set_params>
    <sql>UPDATE producoes SET doi = COALESCE(?, doi), resumo = COALESCE(?, resumo) WHERE id = ?</sql>
    <arguments>
      <argument><name>doi_novo</name></argument>
      <argument><name>resumo_novo</name></argument>
      <argument><name>id</name></argument>
    </arguments>
    <GUI><xloc>1910</xloc><yloc>300</yloc></GUI>
  </transform>

  <!-- ================================================================
       LOG — Artigos com DOI mas sem abstract disponível
       ================================================================ -->
  <transform>
    <name>Filtrar sem resumo</name>
    <type>FilterRows</type>
    <description>Identifica artigos onde o abstract nao estava disponivel na CrossRef</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Log sem_resumo</send_true_to>
    <send_false_to/>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>resumo_novo</leftvalue>
        <function>IS NULL</function>
        <rightvalue/>
      </condition>
    </compare>
    <GUI><xloc>1910</xloc><yloc>440</yloc></GUI>
  </transform>

  <transform>
    <name>Log sem_resumo</name>
    <type>WriteToLog</type>
    <description>Registra artigos sem abstract disponivel na CrossRef (comportamento esperado para muitos periódicos)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <loglevel>Basic</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>SEM RESUMO — abstract nao disponivel na CrossRef para este DOI</logmessage>
    <fields>
      <field><name>id</name></field>
      <field><name>doi_novo</name></field>
    </fields>
    <GUI><xloc>2130</xloc><yloc>440</yloc></GUI>
  </transform>

  <transform_error_handling/>
</pipeline>
