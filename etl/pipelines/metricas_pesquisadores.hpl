<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>metricas_pesquisadores</name>
    <name_hi_res/>
    <description>Fase 5 (SPK-89): Calcula e persiste total_producoes, total_a1_a2 e indice_h para cada pesquisador processado na execucao corrente</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_status>0</pipeline_status>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>SPARK ETL</created_user>
    <created_date>2026/05/23 00:00:00.000</created_date>
    <modified_user>SPARK ETL</modified_user>
    <modified_date>2026/05/23 00:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAA/wMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads>
    <notepad>
      <note>Pipeline SPK-89 — Fase 5
Calcula 3 metricas para cada pesquisador
atualizado na execucao corrente (data_atualizacao
nas ultimas 2 horas):
  total_producoes : COUNT(*) de todas as producoes
  total_a1_a2     : COUNT(*) WHERE qualis IN (A1,A2)
  indice_h        : maior N tal que N producoes
                    possuem jcr &gt;= N

Producoes sem JCR sao excluidas do indice_h.
Um UPDATE por pesquisador (execute_each_row=Y).</note>
      <xloc>50</xloc>
      <yloc>50</yloc>
      <width>430</width>
      <heigth>140</heigth>
      <fontname>Arial</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>14</fontcolorred>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorblue>90</fontcolorblue>
      <backgroundcolorred>201</backgroundcolorred>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorblue>251</backgroundcolorblue>
      <bordercolorred>14</bordercolorred>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorblue>90</bordercolorblue>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Listar Pesquisadores</from>
      <to>Atualizar Metricas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Atualizar Metricas</from>
      <to>Log Erro Metrica</to>
      <enabled>Y</enabled>
    </hop>
  </order>

  <!-- ================================================================
       TRANSFORM 1: Seleciona pesquisadores da execucao corrente
       Usa data_atualizacao para identificar quem foi processado agora.
       Janela de 2h cobre ETLs longos sem selecionar pesquisadores antigos.
       ================================================================ -->
  <transform>
    <name>Listar Pesquisadores</name>
    <type>TableInput</type>
    <description>Seleciona IDs dos pesquisadores atualizados na execucao corrente</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>spark_db</connection>
    <sql>SELECT id FROM pesquisadores WHERE data_atualizacao &gt;= NOW() - INTERVAL '2 hours'</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <GUI>
      <xloc>200</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORM 2: Atualiza as 3 metricas por pesquisador
       execute_each_row=Y — um UPDATE por linha recebida do TableInput.
       Os 4 parametros ? mapeiam para o campo id (repetido 4 vezes):
         ? 1 — pesquisador_id subquery total_producoes
         ? 2 — pesquisador_id subquery total_a1_a2
         ? 3 — pesquisador_id subquery indice_h
         ? 4 — id clausula WHERE
       ================================================================ -->
  <transform>
    <name>Atualizar Metricas</name>
    <type>ExecSQL</type>
    <description>Calcula e persiste total_producoes, total_a1_a2 e indice_h por pesquisador</description>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>spark_db</connection>
    <execute_each_row>Y</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <set_params>Y</set_params>
    <sql>UPDATE pesquisadores SET
  total_producoes = (
    SELECT COUNT(*) FROM producoes WHERE pesquisador_id = ?
  ),
  total_a1_a2 = (
    SELECT COUNT(*) FROM producoes
    WHERE pesquisador_id = ? AND qualis IN ('A1', 'A2')
  ),
  indice_h = (
    SELECT COUNT(*) FROM (
      SELECT jcr, ROW_NUMBER() OVER (ORDER BY jcr DESC) AS pos
      FROM producoes
      WHERE pesquisador_id = ? AND jcr IS NOT NULL
    ) ranked
    WHERE jcr &gt;= pos
  )
WHERE id = ?</sql>
    <arguments>
      <argument><name>id</name></argument>
      <argument><name>id</name></argument>
      <argument><name>id</name></argument>
      <argument><name>id</name></argument>
    </arguments>
    <GUI>
      <xloc>450</xloc>
      <yloc>200</yloc>
    </GUI>
  </transform>

  <!-- ================================================================
       TRANSFORM 3: Log de erros no calculo de metricas
       Falha individual nao interrompe o pipeline.
       ================================================================ -->
  <transform>
    <name>Log Erro Metrica</name>
    <type>WriteToLog</type>
    <description>Registra pesquisadores cujo calculo de metrica falhou (nao interrompe o pipeline)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <loglevel>log_level_error</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>ERRO ao calcular metricas para pesquisador_id: </logmessage>
    <fields>
      <field>
        <name>id</name>
      </field>
    </fields>
    <GUI>
      <xloc>450</xloc>
      <yloc>330</yloc>
    </GUI>
  </transform>

  <transform_error_handling>
    <error>
      <source_transform>Atualizar Metricas</source_transform>
      <target_transform>Log Erro Metrica</target_transform>
      <enabled>Y</enabled>
      <nr_valuename>nrErrors</nr_valuename>
      <descriptions_valuename>errorDescription</descriptions_valuename>
      <fields_valuename>errorFields</fields_valuename>
      <codes_valuename>errorCodes</codes_valuename>
      <max_errors>-1</max_errors>
      <max_pct_errors/>
      <min_pct_rows/>
    </error>
  </transform_error_handling>

</pipeline>
