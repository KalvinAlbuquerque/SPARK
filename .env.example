# Banco de dados local (Docker Compose)
POSTGRES_DB=spark
POSTGRES_USER=spark
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# URL de conexão completa (usada pelo ETL e backend)
DATABASE_URL=postgresql://spark:changeme@localhost:5432/spark

# ETL — Apache Hop
# Diretório com os arquivos XML Lattes para processamento
XML_DIR=./data/xml

# Supabase (produção) — não commitar valores reais
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
