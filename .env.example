# Banco de dados local (Docker Compose)
POSTGRES_DB=spark
POSTGRES_USER=spark
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# URL de conexão completa (usada pelo ETL e backend)
DATABASE_URL=postgresql://spark:changeme@localhost:5432/spark

# ETL — Apache Hop
# Diretório com os arquivos XML Lattes para processamento
XML_DIR=./data/xml

# Supabase (produção) — não commitar valores reais
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# ETL — Enriquecimento externo (SPK-13)
# CrossRef Polite Pool — use seu e-mail para acesso preferencial (sem cadastro necessário)
ETL_EMAIL=seu@email.com

# OpenAlex — crie conta gratuita em openalex.org e copie a key em Settings → API
OPENALEX_APIKEY=
