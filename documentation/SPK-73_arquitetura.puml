@startuml SPK-73_Arquitetura_v4

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam rectangle {
  RoundCorner 10
  BorderThickness 2
}

skinparam component {
  BackgroundColor #FFFCDC
  BorderColor #555555
  FontSize 11
}

skinparam database {
  BackgroundColor #DCF0FF
  BorderColor #0066CC
  FontSize 11
}

skinparam cloud {
  BackgroundColor #F5F5F5
  BorderColor #888888
  FontSize 11
}

skinparam arrow {
  Color #444444
  FontSize 10
}

' ════════════════════════════════════════════════════════
' CAMADA OPERACIONAL
' ════════════════════════════════════════════════════════
rectangle "Camada Operacional" #F0FFF4 {

  component "Base de XML\n(Currículos Lattes)" as XML #FFFCDC
  component "Apache Hop\n(Pipeline ETL)"       as HOP #FFFCDC

  component "Qualis CAPES\n(Planilha CSV)" as QUALIS #F5F5F5
  cloud "CrossRef\n(API DOI + Resumo)"     as CROSSREF
  cloud "OpenAlex\n(API Impact Factor)"    as OPENALEX

  XML      --> HOP : lê XMLs
  QUALIS   --> HOP : lookup ISSN
  CROSSREF --> HOP : lookup DOI\ne resumo
  OPENALEX --> HOP : lookup\nFator de Impacto
}

' ════════════════════════════════════════════════════════
' CAMADA BACK-END
' ════════════════════════════════════════════════════════
rectangle "Camada Back-End  |  Railway" #FFF8F0 {

  database "Supabase\n(PostgreSQL + pgvector)" as DB

  component "FastAPI\n(Python)"                  as API    #FFFCDC
  component "Worker ETL\n(Geração de Embeddings)" as WORKER #FFFCDC
  component "Supabase Auth\n(somente Admin)"      as SBAUTH #FFE8E8

  cloud "Sentence-Transformers\n(Modelo Local)" as ST

  API    --> DB     : consulta /\natualiza
  WORKER --> DB     : persiste\nembeddings
  WORKER --> ST     : gera embedding
  SBAUTH --> DB     : valida role\n(admin)
}

' ════════════════════════════════════════════════════════
' CAMADA FRONT-END
' ════════════════════════════════════════════════════════
rectangle "Camada Front-End" #F0F4FF {

  component "Next.js\n(Vercel)" as NEXT #FFFCDC

  actor "Usuário\n(público)"   as USR
  actor "Admin\n(autenticado)" as ADM

  USR --> NEXT : UC-01 a UC-04\nsem login
  ADM --> NEXT : UC-05\ncom login
}

' ════════════════════════════════════════════════════════
' CONEXÕES ENTRE CAMADAS
' ════════════════════════════════════════════════════════
HOP --> DB     : INSERT /\nUPSERT
HOP --> WORKER : aciona após\ncarga

API --> NEXT   : REST JSON

ADM --> SBAUTH : autentica

@enduml
